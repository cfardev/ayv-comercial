generator client {
	provider = "prisma-client"
	output   = "../generated/prisma"
}

datasource db {
	provider = "postgresql"
}

/// Ancla inicial para la primera migración; reemplazar o extender con modelos de dominio.
model SchemaMeta {
	id        Int      @id @default(autoincrement())
	createdAt DateTime @default(now())

	@@map("schema_meta")
}

model Todo {
	id        String   @id @default(cuid())
	title     String
	done      Boolean  @default(false)
	createdAt DateTime @default(now())

	@@map("todos")
}
