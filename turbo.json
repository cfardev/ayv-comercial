{
	"$schema": "https://turbo.build/schema.json",
	"ui": "stream",
	"globalDependencies": [".env"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},
		"typecheck": {
			"dependsOn": ["^typecheck"],
			"outputs": ["tsconfig.tsbuildinfo", "node_modules/.tmp/*.tsbuildinfo"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {
			"dependsOn": ["^lint"]
		}
	}
}
