# Single shared env at monorepo root (copy to `.env` locally).
# See AGENTS.md — do not commit real secrets.

# --- API (NestJS) — default 4000 if unset ---
PORT=4000

# --- Client (Vite) — default 3000 if unset; override with VITE_PORT ---
VITE_PORT=3000

# DATABASE_URL=postgresql://user:pass@localhost:5432/ayv

# --- Vite dev: proxy /api -> API (Nest usa setGlobalPrefix("api")) ---
# VITE_API_PROXY_TARGET=http://localhost:4000

# --- Client (Vite) — otros VITE_* visibles en el browser vía import.meta.env ---
