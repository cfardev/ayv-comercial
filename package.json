{
	"name": "ayv-comercial",
	"version": "1.0.0",
	"private": true,
	"description": "Monorepo backoffice — Turborepo + pnpm",
	"scripts": {
		"build": "turbo run build",
		"start": "pnpm --filter @ayv-comercial/client run build && pnpm --filter @ayv-comercial/api run build && pnpm --filter @ayv-comercial/api run start:prod",
		"dev": "turbo run dev --log-order stream",
		"lint": "turbo run lint",
		"check": "biome check .",
		"format": "biome format --write .",
		"db:generate": "pnpm --filter @ayv-comercial/api run db:generate",
		"db:migrate": "pnpm --filter @ayv-comercial/api run db:migrate",
		"db:push": "pnpm --filter @ayv-comercial/api run db:push",
		"db:studio": "pnpm --filter @ayv-comercial/api run db:studio",
		"release": "semantic-release",
		"release:dry-run": "semantic-release --dry-run"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.32.1",
	"pnpm": {
		"onlyBuiltDependencies": [
			"prisma",
			"@prisma/engines"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.8",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/exec": "^7.1.0",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/npm": "^13.1.5",
		"semantic-release": "^24.2.9",
		"turbo": "^2.7.5"
	}
}
