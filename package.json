{
	"name": "ayv-comercial",
	"version": "0.0.0",
	"private": true,
	"description": "Monorepo backoffice — Turborepo + pnpm",
	"scripts": {
		"build": "turbo run build",
		"start": "pnpm --filter @ayv-comercial/client run build && pnpm --filter @ayv-comercial/api run build && pnpm --filter @ayv-comercial/api run start:prod",
		"dev": "turbo run dev --log-order stream",
		"lint": "turbo run lint",
		"check": "biome check .",
		"format": "biome format --write .",
		"prisma:generate": "pnpm --filter @ayv-comercial/api run db:generate",
		"prisma:migrate": "pnpm --filter @ayv-comercial/api run db:migrate",
		"prisma:migrate:dev": "pnpm --filter @ayv-comercial/api run db:migrate:dev",
		"prisma:push": "pnpm --filter @ayv-comercial/api run db:push",
		"prisma:studio": "pnpm --filter @ayv-comercial/api run db:studio"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.32.1",
	"pnpm": {
		"onlyBuiltDependencies": [
			" ",
			"\"",
			",",
			"/",
			"@",
			"@nestjs/core",
			"@swc/core",
			"[",
			"]",
			"a",
			"bcrypt",
			"e",
			"g",
			"i",
			"m",
			"msw",
			"n",
			"p",
			"r",
			"s"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.8",
		"turbo": "^2.7.5"
	}
}
