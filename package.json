{
	"name": "ayv-comercial",
	"version": "0.0.0",
	"private": true,
	"description": "Monorepo backoffice — Turborepo + pnpm",
	"scripts": {
		"build": "turbo run build",
		"start": "pnpm --filter @ayv-comercial/client run build && pnpm --filter @ayv-comercial/api run build && pnpm --filter @ayv-comercial/api run start:prod",
		"dev": "turbo run dev --log-order stream",
		"lint": "turbo run lint",
		"check": "biome check .",
		"format": "biome format --write .",
		"db:generate": "pnpm --filter @ayv-comercial/api run db:generate",
		"db:migrate": "pnpm --filter @ayv-comercial/api run db:migrate",
		"db:migrate:dev": "pnpm --filter @ayv-comercial/api run db:migrate:dev",
		"db:push": "pnpm --filter @ayv-comercial/api run db:push",
		"db:studio": "pnpm --filter @ayv-comercial/api run db:studio"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.32.1",
	"pnpm": {
		"onlyBuiltDependencies": [
			"prisma",
			"@prisma/engines"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.8",
		"turbo": "^2.7.5"
	}
}
